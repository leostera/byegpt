{
  "manifest_version": 3,
  "name": "byegpt",
  "version": "0.1.0",
  "description": "Export your own visible ChatGPT chats from a logged-in browser session.",
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "tabs",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://*.oaistatic.com/*",
    "https://*.oaiusercontent.com/*",
    "https://cdn.openai.com/*"
  ],
  "action": {
    "default_title": "byegpt",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "injected.js"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ]
    }
  ]
}
