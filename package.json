{
  "name": "byegpt-dev",
  "private": true,
  "version": "0.1.0",
  "description": "Development tooling for the ByeGPT repository.",
  "scripts": {
    "generate:assets": "python3 scripts/generate_store_assets.py",
    "build:extension": "python3 scripts/package_extension.py",
    "format": "biome format --write .",
    "format:check": "biome check . --linter-enabled=false --organize-imports-enabled=false --assists-enabled=false",
    "lint": "eslint .",
    "typecheck": "tsc --project tsconfig.json",
    "test:js": "node --test tests-js/*.test.mjs",
    "test:python": "python3 -m unittest discover -s tests -v",
    "test": "npm run test:js && npm run test:python",
    "check:all": "npm run format:check && npm run lint && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@eslint/js": "^9.23.0",
    "@types/chrome": "^0.0.322",
    "@types/node": "^22.13.14",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "typescript": "^5.8.2"
  }
}
