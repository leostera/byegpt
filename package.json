{
  "name": "byegpt-dev",
  "private": true,
  "version": "0.1.0",
  "description": "Development tooling for the ByeGPT repository.",
  "scripts": {
    "generate:assets": "python3 scripts/generate_store_assets.py",
    "dev": "vite --config vite.config.mjs",
    "build:extension": "vite build --config vite.config.mjs && node scripts/write_zip_checksum.mjs",
    "publish:chrome": "chrome-webstore-upload",
    "fix": "npm run format && eslint . --fix",
    "format": "biome format --write .",
    "format:check": "biome check . --linter-enabled=false --organize-imports-enabled=false --assists-enabled=false",
    "lint": "eslint .",
    "typecheck": "tsc --project tsconfig.json",
    "check:scripts": "python3 -m py_compile scripts/generate_store_assets.py",
    "test:js": "node --test tests-js/*.test.mjs",
    "test": "npm run test:js",
    "check:all": "npm run format:check && npm run lint && npm run typecheck && npm run check:scripts && npm run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@crxjs/vite-plugin": "^2.2.0",
    "@eslint/js": "^9.23.0",
    "@types/chrome": "^0.0.322",
    "@types/node": "^22.13.14",
    "chrome-webstore-upload-cli": "^3.4.0",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.3.5",
    "vite-plugin-zip-pack": "^1.2.4"
  }
}
